{
  "name": "@cognitive-substrate/kafka-bus",
  "version": "0.1.0",
  "description": "Typed Kafka producers, consumers, topic registry, and W3C trace propagation for Cognitive Substrate",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@cognitive-substrate/core-types": "workspace:*",
    "kafkajs": "^2.2.4"
  },
  "devDependencies": {
    "typescript": "^5.5.0"
  }
}
