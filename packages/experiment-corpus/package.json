{
  "name": "@cognitive-substrate/experiment-corpus",
  "version": "0.1.0",
  "description": "Fixed replay corpus and experiment harness utilities for cognitive substrate evaluation",
  "license": "PolyForm-Noncommercial-1.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
