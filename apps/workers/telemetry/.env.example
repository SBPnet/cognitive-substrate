# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=telemetry-worker
KAFKA_SSL=false
# KAFKA_SASL_MECHANISM=scram-sha-256
# KAFKA_SASL_USERNAME=
# KAFKA_SASL_PASSWORD=

# ClickHouse — use CLICKHOUSE_URL for local HTTP (http://localhost:8123)
# or CLICKHOUSE_HOST + CLICKHOUSE_PORT for Aiven HTTPS
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_DATABASE=cognitive_substrate_telemetry
CLICKHOUSE_USERNAME=default
CLICKHOUSE_PASSWORD=
# Aiven pattern (overrides CLICKHOUSE_URL when set):
# CLICKHOUSE_HOST=<host>
# CLICKHOUSE_PORT=8443
# CLICKHOUSE_USERNAME=cognitive-substrate-app
# CLICKHOUSE_PASSWORD=<password>

# Telemetry
OTEL_SERVICE_NAME=telemetry-worker
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_SDK_DISABLED=false

# Worker
KAFKA_GROUP_ID=telemetry-workers
ENVIRONMENT=dev
TELEMETRY_EXPERIENCE_ENABLED=true
TELEMETRY_EXPERIENCE_WINDOW_MS=60000
VERTEX_EMBED_COST_PER_MILLION_TOKENS_USD=0.15
