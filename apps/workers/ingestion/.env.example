# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=ingestion-worker
KAFKA_SSL=false
# KAFKA_SASL_MECHANISM=scram-sha-256
# KAFKA_SASL_USERNAME=
# KAFKA_SASL_PASSWORD=

# OpenSearch
OPENSEARCH_URL=http://localhost:9200
# OPENSEARCH_USERNAME=
# OPENSEARCH_PASSWORD=
# OPENSEARCH_TLS_REJECT_UNAUTHORIZED=true

# Object Storage (S3-compatible)
S3_BUCKET=cognitive-substrate-episodic
S3_REGION=us-east-1
# S3_ENDPOINT=http://localhost:9000       # for MinIO
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_FORCE_PATH_STYLE=false

# Embedding — single-provider legacy path (used when EMBEDDING_LANES is not set)
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536
# OPENAI_API_KEY=
# EMBEDDING_ENDPOINT=https://api.openai.com/v1/embeddings
# For Vertex AI local tests, set EMBEDDING_PROVIDER=vertex and authenticate with
# gcloud auth application-default login. Hosted environments can set
# GOOGLE_APPLICATION_CREDENTIALS_JSON to a service-account or ADC JSON secret.
# GCP_PROJECT_ID=
# GCP_LOCATION=us-central1
# VERTEX_EMBED_MODEL=gemini-embedding-001
# GOOGLE_APPLICATION_CREDENTIALS_JSON=

# Multi-profile embedding (model-swap testing)
# Set EMBEDDING_LANES to activate the multi-profile path.
# Each lane reads config from its own prefixed variables.
# EMBEDDING_LANES=quality,efficient
#
# Quality lane (Qwen3-Embedding-0.6B default, dim 1024)
# QUALITY_EMBEDDING_PROVIDER=openai_compat
# QUALITY_EMBEDDING_ENDPOINT=http://localhost:11434/v1/embeddings
# QUALITY_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B
# QUALITY_EMBEDDING_APIKEY=
# QUALITY_EMBEDDING_DIMENSION=1024
#
# Efficient lane (Nomic Embed Text v2 default, dim 768)
# EFFICIENT_EMBEDDING_PROVIDER=openai_compat
# EFFICIENT_EMBEDDING_ENDPOINT=http://localhost:11435/v1/embeddings
# EFFICIENT_EMBEDDING_MODEL=nomic-ai/nomic-embed-text-v2-moe
# EFFICIENT_EMBEDDING_APIKEY=
# EFFICIENT_EMBEDDING_DIMENSION=768
#
# Hybrid lane (BGE-M3, optional — add after dense-only gaps surface)
# HYBRID_EMBEDDING_PROVIDER=openai_compat
# HYBRID_EMBEDDING_ENDPOINT=http://localhost:11436/v1/embeddings
# HYBRID_EMBEDDING_MODEL=BAAI/bge-m3
# HYBRID_EMBEDDING_APIKEY=
# HYBRID_EMBEDDING_DIMENSION=1024
#
# Stub mode for local/CI testing without real inference endpoints
# EMBEDDING_LANES=quality,efficient
# QUALITY_EMBEDDING_PROVIDER=stub
# EFFICIENT_EMBEDDING_PROVIDER=stub
#
# ML Commons/Aiven placement validation (experimental smoke lane)
# AIVEN_ML_NODE_EXPECTED_SETTING=false
# AIVEN_ML_NODE_EXPECTED_HAS_ML_ROLE=false
# AIVEN_ML_NODE_TEST_PREDICT_PATH=/_plugins/_ml/_predict/text_embedding/<model-id>
# AIVEN_ML_NODE_TEST_PREDICT_BODY={"text_docs":["placement probe"],"return_number":true}
# AIVEN_ML_NODE_STRICT=false

# Telemetry
OTEL_SERVICE_NAME=ingestion-worker
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_SDK_DISABLED=false

# Worker
KAFKA_GROUP_ID=ingestion-workers
