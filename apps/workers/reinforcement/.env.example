# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=reinforcement-worker
KAFKA_SSL=false
# KAFKA_SASL_MECHANISM=scram-sha-256
# KAFKA_SASL_USERNAME=
# KAFKA_SASL_PASSWORD=

# OpenSearch
OPENSEARCH_URL=http://localhost:9200
# OPENSEARCH_USERNAME=
# OPENSEARCH_PASSWORD=
# OPENSEARCH_TLS_REJECT_UNAUTHORIZED=true

# ClickHouse — use CLICKHOUSE_URL for local HTTP (http://localhost:8123)
# or CLICKHOUSE_HOST + CLICKHOUSE_PORT for Aiven HTTPS
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_DATABASE=cognitive_substrate_telemetry
CLICKHOUSE_USERNAME=default
CLICKHOUSE_PASSWORD=
# CLICKHOUSE_HOST=<host>
# CLICKHOUSE_PORT=8443
# CLICKHOUSE_USERNAME=cognitive-substrate-app
# CLICKHOUSE_PASSWORD=<password>

# Telemetry
OTEL_SERVICE_NAME=reinforcement-worker
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_SDK_DISABLED=false

# Worker
LOG_LEVEL=info
KAFKA_GROUP_ID=reinforcement-workers
ENVIRONMENT=dev
