# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=orchestrator
KAFKA_SSL=false
# KAFKA_SASL_MECHANISM=scram-sha-256
# KAFKA_SASL_USERNAME=
# KAFKA_SASL_PASSWORD=

# OpenSearch
OPENSEARCH_URL=http://localhost:9200
# OPENSEARCH_USERNAME=
# OPENSEARCH_PASSWORD=
# OPENSEARCH_TLS_REJECT_UNAUTHORIZED=true

# Embedding
EMBEDDING_PROVIDER=stub
EMBEDDING_DIMENSION=1536
# For Vertex AI local tests, set EMBEDDING_PROVIDER=vertex and authenticate with
# gcloud auth application-default login. Hosted environments can set
# GOOGLE_APPLICATION_CREDENTIALS_JSON to a service-account or ADC JSON secret.
# GCP_PROJECT_ID=
# GCP_LOCATION=us-central1
# VERTEX_EMBED_MODEL=gemini-embedding-001
# GOOGLE_APPLICATION_CREDENTIALS_JSON=

# Telemetry
OTEL_SERVICE_NAME=orchestrator
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_SDK_DISABLED=false

# Worker
KAFKA_GROUP_ID=orchestrators
