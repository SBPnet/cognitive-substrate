{
  "name": "@cognitive-substrate/api",
  "version": "0.1.0",
  "description": "API/BFF gateway for the Cognitive Substrate cognitive workbench",
  "license": "PolyForm-Noncommercial-1.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
