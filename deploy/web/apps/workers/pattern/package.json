{
  "name": "@cognitive-substrate/pattern-worker",
  "version": "0.1.0",
  "description": "Pattern detection worker — matches operational primitive streams against the pattern library and emits anomalies and recommendations",
  "license": "PolyForm-Noncommercial-1.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/main.js",
    "dev": "node --watch dist/main.js",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@cognitive-substrate/abstraction-engine": "workspace:*",
    "@cognitive-substrate/clickhouse-telemetry": "workspace:*",
    "@cognitive-substrate/kafka-bus": "workspace:*",
    "@cognitive-substrate/memory-opensearch": "workspace:*",
    "@cognitive-substrate/telemetry-otel": "workspace:*",
    "@opensearch-project/opensearch": "^2.7.0",
    "@opentelemetry/api": "^1.9.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0"
  }
}
