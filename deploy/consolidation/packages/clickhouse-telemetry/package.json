{
  "name": "@cognitive-substrate/clickhouse-telemetry",
  "version": "0.1.0",
  "description": "ClickHouse client, table schemas, and typed batch inserters for the Cognitive Substrate temporal telemetry layer",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@clickhouse/client": "^1.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.18",
    "typescript": "^5.5.0"
  }
}
