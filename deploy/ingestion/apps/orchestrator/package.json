{
  "name": "@cognitive-substrate/orchestrator",
  "version": "0.1.0",
  "description": "Stage 5 cognitive loop orchestrator for the Cognitive Substrate architecture",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "main": "./dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/main.js",
    "dev": "node --watch dist/main.js",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@cognitive-substrate/agents": "workspace:*",
    "@cognitive-substrate/constitution-engine": "workspace:*",
    "@cognitive-substrate/core-types": "workspace:*",
    "@cognitive-substrate/development-engine": "workspace:*",
    "@cognitive-substrate/kafka-bus": "workspace:*",
    "@cognitive-substrate/memory-opensearch": "workspace:*",
    "@cognitive-substrate/world-model": "workspace:*",
    "@cognitive-substrate/policy-engine": "workspace:*",
    "@cognitive-substrate/retrieval-engine": "workspace:*",
    "@cognitive-substrate/telemetry-otel": "workspace:*",
    "@opensearch-project/opensearch": "^2.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0"
  }
}
